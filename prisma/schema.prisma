generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id @default(cuid())
  telegramId               String                    @unique @map("telegram_id")
  username                 String?
  firstName                String?                   @map("first_name")
  lastName                 String?                   @map("last_name")
  language                 String                    @default("ru")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  lastActive               DateTime?                 @map("last_active")
  tags                     String[]                  @default([])
  phoneNumber              String?                   @map("phone_number")
  currentProfileId         String?                   @map("current_profile_id")
  botMessages              BotMessage[]
  broadcastLogs            BroadcastLog[]
  cart                     Cart[]
  clientLogs               ClientLog[]
  entitlements             Entitlement[]
  payments                 Payment[]
  plan28s                  Plan28[]
  planFeedbacks            PlanFeedback[]
  planProgress             PlanProgress?
  productReplacements      ProductReplacement[]
  questionnaireProgress    QuestionnaireProgress[]
  questionnaireSubmissions QuestionnaireSubmission[]
  recommendationSessions   RecommendationSession[]
  skinProfiles             SkinProfile[]
  supportChats             SupportChat[]
  userAnswers              UserAnswer[]
  userPreferences          UserPreferences?
  currentProfile           SkinProfile?              @relation("CurrentProfile", fields: [currentProfileId], references: [id])
  wishlist                 Wishlist[]
  wishlistFeedbacks        WishlistFeedback[]

  @@index([lastActive])
  @@index([currentProfileId])
  @@map("users")
}

model SkinProfile {
  id                       String                    @id @default(cuid())
  userId                   String                    @map("user_id")
  version                  Int                       @default(1)
  skinType                 String?                   @map("skin_type")
  sensitivityLevel         String?                   @map("sensitivity_level")
  dehydrationLevel         Int?                      @map("dehydration_level")
  acneLevel                Int?                      @map("acne_level")
  rosaceaRisk              String?                   @map("rosacea_risk")
  pigmentationRisk         String?                   @map("pigmentation_risk")
  ageGroup                 String?                   @map("age_group")
  hasPregnancy             Boolean?                  @default(false) @map("has_pregnancy")
  medicalMarkers           Json?                     @map("medical_markers")
  notes                    String?
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  plan28s                  Plan28[]
  questionnaireSubmissions QuestionnaireSubmission[]
  recommendationSessions   RecommendationSession[]
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentProfileUsers      User[]                    @relation("CurrentProfile")

  @@unique([userId, version])
  @@index([userId])
  @@map("skin_profiles")
}

model Questionnaire {
  id             Int                       @id @default(autoincrement())
  name           String
  version        Int                       @unique @default(1)
  isActive       Boolean                   @default(false) @map("is_active")
  createdAt      DateTime                  @default(now()) @map("created_at")
  questionGroups QuestionGroup[]
  progress       QuestionnaireProgress[]
  submissions    QuestionnaireSubmission[]
  questions      Question[]
  userAnswers    UserAnswer[]

  @@map("questionnaires")
}

model QuestionGroup {
  id              Int           @id @default(autoincrement())
  questionnaireId Int           @map("questionnaire_id")
  title           String
  position        Int
  createdAt       DateTime      @default(now()) @map("created_at")
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  questions       Question[]

  @@index([questionnaireId])
  @@map("question_groups")
}

model Question {
  id              Int            @id @default(autoincrement())
  questionnaireId Int            @map("questionnaire_id")
  groupId         Int?           @map("group_id")
  code            String
  text            String
  type            String
  position        Int
  isRequired      Boolean        @default(true) @map("is_required")
  createdAt       DateTime       @default(now()) @map("created_at")
  answerOptions   AnswerOption[]
  group           QuestionGroup? @relation(fields: [groupId], references: [id])
  questionnaire   Questionnaire  @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  userAnswers     UserAnswer[]

  @@index([questionnaireId])
  @@index([groupId])
  @@map("questions")
}

model AnswerOption {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  value      String
  label      String
  position   Int
  scoreJson  Json?    @map("score_json")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("answer_options")
}

model UserAnswer {
  id              Int           @id @default(autoincrement())
  userId          String        @map("user_id")
  questionnaireId Int           @map("questionnaire_id")
  questionId      Int           @map("question_id")
  answerValue     String?       @map("answer_value")
  answerValues    Json?         @map("answer_values")
  createdAt       DateTime      @default(now()) @map("created_at")
  question        Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionnaireId, questionId])
  @@index([userId])
  @@index([questionnaireId])
  @@index([questionId])
  @@map("user_answers")
}

/// Метаданные позиции в анкете для синхронизации между устройствами
model QuestionnaireProgress {
  id              Int           @id @default(autoincrement())
  userId          String        @map("user_id")
  questionnaireId Int           @map("questionnaire_id")
  questionIndex   Int           @default(0) @map("question_index")
  infoScreenIndex Int           @default(0) @map("info_screen_index")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionnaireId])
  @@index([userId])
  @@index([questionnaireId])
  @@map("questionnaire_progress")
}

/// Фиксирует финальные отправки анкеты и обеспечивает идемпотентность по clientSubmissionId
model QuestionnaireSubmission {
  id                 String        @id @default(cuid())
  userId             String        @map("user_id")
  questionnaireId    Int           @map("questionnaire_id")
  clientSubmissionId String?       @map("client_submission_id")
  profileId          String?       @map("profile_id")
  profileVersion     Int?          @map("profile_version")
  createdAt          DateTime      @default(now()) @map("created_at")
  status             String        @default("pending") @map("status")
  errorMessage       String?       @map("error_message")
  profile            SkinProfile?  @relation(fields: [profileId], references: [id])
  questionnaire      Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionnaireId, clientSubmissionId])
  @@unique([userId, questionnaireId])
  @@index([userId])
  @@index([questionnaireId])
  @@index([profileId])
  @@map("questionnaire_submissions")
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  country   String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  logoUrl   String?   @map("logo_url")
  slug      String?   @unique
  products  Product[]

  @@map("brands")
}

model Product {
  id                     Int                  @id @default(autoincrement())
  brandId                Int                  @map("brand_id")
  name                   String
  line                   String?
  category               String
  step                   String
  skinTypes              String[]             @default([]) @map("skin_types")
  concerns               String[]             @default([])
  isFragranceFree        Boolean              @default(false) @map("is_fragrance_free")
  isNonComedogenic       Boolean              @default(false) @map("is_non_comedogenic")
  priceSegment           String?              @map("price_segment")
  descriptionUser        String?              @map("description_user")
  marketLinks            Json?                @map("market_links")
  status                 String               @default("draft")
  imageUrl               String?              @map("image_url")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  price                  Int?
  activeIngredients      String[]             @default([]) @map("active_ingredients")
  avoidIf                String[]             @default([]) @map("avoid_if")
  description            String?
  gallery                String[]             @default([])
  isHero                 Boolean              @default(false) @map("is_hero")
  link                   String?
  priority               Int                  @default(0)
  published              Boolean              @default(true)
  slug                   String?              @unique
  volume                 String?
  composition            String?
  cart                   Cart[]
  newProductReplacements ProductReplacement[] @relation("NewProduct")
  oldProductReplacements ProductReplacement[] @relation("OldProduct")
  brand                  Brand                @relation(fields: [brandId], references: [id])
  wishlist               Wishlist[]
  wishlistFeedbacks      WishlistFeedback[]

  @@index([brandId])
  @@index([status])
  @@index([published])
  @@index([step])
  @@index([isHero, priority])
  @@map("products")
}

model RecommendationRule {
  id                     Int                     @id @default(autoincrement())
  name                   String
  conditionsJson         Json                    @map("conditions_json")
  stepsJson              Json                    @map("steps_json")
  priority               Int                     @default(0)
  isActive               Boolean                 @default(true) @map("is_active")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  recommendationSessions RecommendationSession[]
  history                RecommendationRuleHistory[]

  @@index([isActive, priority])
  @@map("recommendation_rules")
}

model RecommendationSession {
  id        Int                 @id @default(autoincrement())
  userId    String              @map("user_id")
  profileId String              @map("profile_id")
  ruleId    Int?                @map("rule_id")
  products  Json
  createdAt DateTime            @default(now()) @map("created_at")
  profile   SkinProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rule      RecommendationRule? @relation(fields: [ruleId], references: [id])
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
  @@index([createdAt])
  @@map("recommendation_sessions")
}

model RecommendationRuleHistory {
  id             Int                @id @default(autoincrement())
  ruleId         Int                @map("rule_id")
  name           String
  conditionsJson Json               @map("conditions_json")
  stepsJson      Json               @map("steps_json")
  priority       Int
  isActive       Boolean            @map("is_active")
  version        Int
  createdBy      String?            @map("created_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  rule           RecommendationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, version])
  @@map("recommendation_rule_history")
}

model Admin {
  id               Int      @id @default(autoincrement())
  email            String?  @unique
  passwordHash     String?  @map("password_hash")
  role             String   @default("editor")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  telegramId       String?  @unique @map("telegram_id")
  telegramUsername String?  @unique @map("telegram_username")

  @@map("admins")
}

model AdminWhitelist {
  id          Int      @id @default(autoincrement())
  phoneNumber String?  @unique @map("phone_number")
  telegramId  String?  @unique @map("telegram_id")
  name        String?
  role        String   @default("admin")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_whitelist")
}

model AdminEmailWhitelist {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_email_whitelist")
}

model PlanFeedback {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  rating    Int
  feedback  String?
  createdAt DateTime @default(now()) @map("created_at")
  type      String   @default("plan_recommendations")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([rating])
  @@index([type])
  @@map("plan_feedback")
}

model Plan28 {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  skinProfileId  String      @map("skin_profile_id")
  profileVersion Int         @map("profile_version")
  planData       Json        @map("plan_data")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  skinProfile    SkinProfile @relation(fields: [skinProfileId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileVersion])
  @@index([userId])
  @@index([skinProfileId])
  @@index([profileVersion])
  @@map("plan28")
}

model PlanProgress {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  currentDay         Int      @default(1)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  completedDays      Int[]    @default([]) @map("completed_days")
  currentStreak      Int      @default(0) @map("current_streak")
  longestStreak      Int      @default(0) @map("longest_streak")
  totalCompletedDays Int      @default(0) @map("total_completed_days")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("plan_progress")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("cart")
}

model WishlistFeedback {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  feedback  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([feedback])
  @@index([createdAt])
  @@map("wishlist_feedback")
}

model ProductReplacement {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  oldProductId Int      @map("old_product_id")
  newProductId Int      @map("new_product_id")
  reason       String
  createdAt    DateTime @default(now()) @map("created_at")
  newProduct   Product  @relation("NewProduct", fields: [newProductId], references: [id], onDelete: Cascade)
  oldProduct   Product  @relation("OldProduct", fields: [oldProductId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([oldProductId])
  @@index([newProductId])
  @@map("product_replacements")
}

model BotMessage {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  telegramId  String   @map("telegram_id")
  chatId      String   @map("chat_id")
  direction   String
  messageType String   @map("message_type")
  content     String?
  rawData     Json?    @map("raw_data")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
  @@index([createdAt])
  @@index([direction])
  @@map("bot_messages")
}

model BroadcastMessage {
  id          String         @id @default(cuid())
  title       String
  message     String
  filtersJson Json           @map("filters_json")
  status      String         @default("draft")
  scheduledAt DateTime?      @map("scheduled_at")
  sentCount   Int            @default(0) @map("sent_count")
  failedCount Int            @default(0) @map("failed_count")
  totalCount  Int            @default(0) @map("total_count")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  sentAt      DateTime?      @map("sent_at")
  buttonsJson Json?          @map("buttons_json")
  imageUrl    String?        @map("image_url")
  logs        BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcast_messages")
}

model SupportChat {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  unread        Int              @default(0)
  unreadAdmin   Int              @default(0) @map("unread_admin")
  lastMessage   String?          @map("last_message")
  status        String           @default("active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  autoReplySent Boolean          @default(false) @map("auto_reply_sent")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt])
  @@map("support_chats")
}

model SupportMessage {
  id          String      @id @default(cuid())
  chatId      String      @map("chat_id")
  text        String
  isAdmin     Boolean     @default(false) @map("is_admin")
  attachments Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  chat        SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
  @@map("support_messages")
}

model BroadcastLog {
  id           String           @id @default(cuid())
  broadcastId  String           @map("broadcast_id")
  userId       String           @map("user_id")
  telegramId   String           @map("telegram_id")
  status       String
  errorMessage String?          @map("error_message")
  sentAt       DateTime         @default(now()) @map("sent_at")
  broadcast    BroadcastMessage @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([userId])
  @@index([status])
  @@map("broadcast_logs")
}

model ClientLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  level     String
  message   String
  context   Json?
  userAgent String?  @map("user_agent")
  url       String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@index([createdAt])
  @@map("client_logs")
}

model UserPreferences {
  id                         String    @id @default(cuid())
  userId                     String    @unique @map("user_id")
  isRetakingQuiz             Boolean   @default(false) @map("is_retaking_quiz")
  fullRetakeFromHome         Boolean   @default(false) @map("full_retake_from_home")
  paymentRetakingCompleted   Boolean   @default(false) @map("payment_retaking_completed")
  paymentFullRetakeCompleted Boolean   @default(false) @map("payment_full_retake_completed")
  hasPlanProgress            Boolean   @default(false) @map("has_plan_progress")
  routineProducts            Json?     @map("routine_products")
  planFeedbackSent           Boolean   @default(false) @map("plan_feedback_sent")
  serviceFeedbackSent        Boolean   @default(false) @map("service_feedback_sent")
  lastPlanFeedbackDate       DateTime? @map("last_plan_feedback_date")
  lastServiceFeedbackDate    DateTime? @map("last_service_feedback_date")
  extra                      Json?
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  productCode       String        @map("product_code")
  amount            Int
  currency          String        @default("RUB")
  provider          String
  providerPaymentId String?       @unique @map("provider_payment_id")
  providerPayload   Json?         @map("provider_payload")
  status            String
  idempotencyKey    String?       @unique @map("idempotency_key")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  entitlements      Entitlement[] @relation("EntitlementPayment")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([providerPaymentId])
  @@index([status])
  @@index([idempotencyKey])
  @@map("payments")
}

model Entitlement {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  code          String
  active        Boolean   @default(false)
  validUntil    DateTime? @map("valid_until")
  lastPaymentId String?   @map("last_payment_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastPayment   Payment?  @relation("EntitlementPayment", fields: [lastPaymentId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
  @@index([active, validUntil])
  @@map("entitlements")
}
