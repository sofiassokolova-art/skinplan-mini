# База данных Neon (получите connection string на https://neon.tech в проекте neon-red-yacht)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Telegram Bot Token (получите у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# JWT Secret (случайная строка, можно сгенерировать: openssl rand -hex 32)
JWT_SECRET="your-random-secret-key-here"

# Данные для локального npm run seed:admin.
# Пароль должен быть уникальным, минимум 12 символов; скрипт не печатает его в лог.
ADMIN_SEED_EMAIL="admin@skiniq.app"
ADMIN_SEED_PASSWORD="your-unique-admin-seed-password"

# Ключ шифрования персональных данных (AES-256-GCM, 32 байта).
# Сгенерируйте: openssl rand -hex 32
# ОБЯЗАТЕЛЕН в production (без него запись ПДн упадёт). Хранить как секрет, не коммитить.
# При смене ключа ранее зашифрованные данные станут нечитаемыми — нужна ре-миграция.
PII_ENCRYPTION_KEY="your-32-byte-hex-key-here"

# Секрет для внешнего планировщика (GitHub Actions) — общий для всех /api/cron/*.
CRON_SECRET="your-cron-secret-here"

# Adv.Cake: токен XML-выгрузки заказов (хвост /export/webmaster/<TOKEN>). Секрет!
# Кабинет → Настройки. Используется кроном /api/cron/advcake-sync и админкой.
ADVCAKE_EXPORT_TOKEN="your-advcake-export-token"
# Алиас оффера для синка (по умолчанию goldappleru).
ADVCAKE_OFFER="goldappleru"
